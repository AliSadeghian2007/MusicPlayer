}

QScrollArea#playlistsScrollArea QScrollBar:vertical {
    background-color: #eeeeee;
    width: 10px;
    margin: 0px;
    border: none;
    border-radius: 5px;
}

QScrollArea#playlistsScrollArea QScrollBar::handle:vertical {
    background-color: #b5b5b5;
    min-height: 25px;
    border-radius: 5px;
}

QScrollArea#playlistsScrollArea QScrollBar::handle:vertical:hover {
    background-color: #999999;
}

QScrollArea#playlistsScrollArea QScrollBar::add-line:vertical,
QScrollArea#playlistsScrollArea QScrollBar::sub-line:vertical {
    width: 0px;
    height: 0px;
}

