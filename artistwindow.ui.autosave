         <property name="styleSheet">
          <string notr="true">QScrollArea#albumsScrollArea {
    background-color: transparent;
    border: none;
}

QScrollArea#albumsScrollArea QWidget#qt_scrollarea_viewport {
    background-color: transparent;
}

QScrollArea#albumsScrollArea QScrollBar:vertical {
    background-color: #eeeeee;
    width: 10px;
    margin: 0px;
    border: none;
    border-radius: 5px;
}

QScrollArea#albumsScrollArea QScrollBar::handle:vertical {
    background-color: #b5b5b5;
    min-height: 25px;
    border-radius: 5px;
}

QScrollArea#albumsScrollArea QScrollBar::handle:vertical:hover {
    background-color: #999999;
}

QScrollArea#albumsScrollArea QScrollBar::add-line:vertical,
QScrollArea#albumsScrollArea QScrollBar::sub-line:vertical {
    width: 0px;
    height: 0px;
}

QScrollArea#albumsScrollArea QScrollBar::add-page:vertical,
QScrollArea#albumsScrollArea QScrollBar::sub-page:vertical {
    background-color: transparent;
}</string>
         </property>
