      <property name="styleSheet">
       <string notr="true">QWidget#bottomBarWidget {
    background-color: transparent;
}

QWidget#bottomBarWidget QToolButton {
    background-color: #ffffff;
    color: #303030;
    border: 1px solid #c9c9c9;
    border-radius: 8px;
    padding: 5px;
    font-size: 12px;
}

QWidget#bottomBarWidget QToolButton:hover {
    background-color: #eeeeee;
    border-color: #a5a5a5;
}

QWidget#bottomBarWidget QToolButton:pressed {
    background-color: #d8d8d8;
}

QWidget#bottomBarWidget QToolButton:disabled {
    background-color: #f4f4f4;
    color: #aaaaaa;
    border-color: #dddddd;
}

QToolButton#deleteAlbumButton {
    color: #b3261e;
}

QToolButton#logoutButton {
    color: #b3261e;
}</string>
